{
  "name": "novel-tracker",
  "version": "0.1.0",
  "private": true,
  "description": "桌面端追更控制台 - 资深读者的网文管理工具",
  "author": "Novel Tracker",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron": "cross-env NODE_ENV=development electron .",
    "electron:wait": "wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently -k \"npm:dev\" \"npm:electron:wait\"",
    "electron:build": "npm run build && electron-builder --publish=never",
    "electron:build:win": "npm run build && electron-builder --win --publish=never",
    "electron:build:win:portable": "npm run build && electron-builder --win portable --publish=never",
    "electron:build:mac": "npm run build && electron-builder --mac --publish=never",
    "electron:build:linux": "npm run build && electron-builder --linux --publish=never"
  },
  "dependencies": {
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "typescript": "^5.2.2",
    "vite": "^5.1.4",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.noveltracker.app",
    "productName": "追更控制台",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "asar": true,
    "asarUnpack": [],
    "files": [
      {
        "from": "dist",
        "to": "dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "electron",
        "to": "electron",
        "filter": [
          "**/*"
        ]
      },
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.cjs"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "artifactName": "追更控制台-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "追更控制台",
      "runAfterFinish": true
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.productivity",
      "artifactName": "追更控制台-${version}-${arch}.${ext}"
    },
    "linux": {
      "target": ["deb", "AppImage"],
      "category": "Utility",
      "artifactName": "追更控制台-${version}-${arch}.${ext}"
    }
  }
}
